1) Reverse Linked List :
Time complexity : O(n)
Spce complexity : O(1)

ListNode* reverseList(ListNode* head){
     ListNode* prev=NULL;
     ListNode* curr=head;
     ListNode* next=NULL;

     while(curr!=NULL){
         next=curr->next;
         curr->next=prev;
         prev=curr;
         curr=next;
     }
     return prev;
}
